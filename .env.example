# Directus API Configuration (Required)
NEXT_PUBLIC_DIRECTUS_URL=https://admin.trotta.co

# Asset serving URL (Optional - defaults to NEXT_PUBLIC_DIRECTUS_URL)
NEXT_PUBLIC_ASSETS_URL=https://assets.trotta.co

# Application URL for OAuth callbacks (Required for auth)
NEXT_PUBLIC_APP_URL=https://trotta.co

# Public token for accessing protected collections (Optional)
DIRECTUS_PUBLIC_TOKEN=your_public_token_here

# Application Environment
NODE_ENV=production
